{
  "name": "@poluruprvn/pug-web",
  "version": "0.0.8",
  "description": "Pug Web SDK for event tracking",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "pug_sw.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "echo \"export const SDK_VERSION = '$(node -p \"require('./package.json').version\")'\" > src/version.ts",
    "build": "tsc",
    "watch": "tsc -w",
    "dev": "tsc -w & serve . & sleep 1 && open http://localhost:3000 && wait",
    "serve": "serve . & sleep 1 && open http://localhost:3000 && wait",
    "lint": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@bufbuild/protovalidate": "^1.1.1",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1",
    "uuidv7": "^1.1.0"
  },
  "keywords": [
    "analytics",
    "tracking",
    "sdk"
  ],
  "author": "Pug",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@bufbuild/protoc-gen-es": "^2.12.1",
    "jsdom": "^29.0.1",
    "serve": "^14.2.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  }
}
