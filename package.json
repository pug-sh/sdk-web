{
  "name": "pug-web",
  "version": "0.0.1",
  "description": "Pug Web SDK for event tracking",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prebuild": "echo \"export const SDK_VERSION = '$(node -p \"require('./package.json').version\")'\" > src/version.ts",
    "build": "tsc",
    "watch": "tsc -w",
    "dev": "tsc -w & serve . & sleep 1 && open http://localhost:3000 && wait",
    "serve": "serve . & sleep 1 && open http://localhost:3000 && wait",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@buf/fivebits_pug.bufbuild_es": "2.12.0-20260506044109-e00079fd5b34.1",
    "@bufbuild/protobuf": "^2.11.0",
    "@bufbuild/protovalidate": "^1.1.1",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1",
    "uuidv7": "^1.1.0"
  },
  "keywords": [
    "analytics",
    "tracking",
    "sdk"
  ],
  "author": "Pug",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.4.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.5.0",
    "serve": "^14.2.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.45.0",
    "vitest": "^4.1.1"
  },
  "prettier": {
    "arrowParens": "avoid",
    "printWidth": 120,
    "singleQuote": true,
    "semi": false,
    "tabWidth": 2,
    "trailingComma": "es5"
  }
}
