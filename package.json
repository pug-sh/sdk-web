{
  "name": "@poluruprvn/pug-web",
  "version": "0.0.8",
  "description": "Pug Web SDK for event tracking",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prebuild": "echo \"export const SDK_VERSION = '$(node -p \"require('./package.json').version\")'\" > src/version.ts && node scripts/gen-well-known-events.mjs",
    "build": "tsc",
    "watch": "tsc -w",
    "dev": "tsc -w & serve . & sleep 1 && open http://localhost:3000 && wait",
    "serve": "serve . & sleep 1 && open http://localhost:3000 && wait",
    "lint": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@buf/pugsh_pug.bufbuild_es": "2.12.1-20260703054414-34cac42a0ae0.1",
    "@bufbuild/protobuf": "^2.12.0",
    "@bufbuild/protovalidate": "^1.1.1",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1",
    "uuidv7": "^1.1.0"
  },
  "keywords": [
    "analytics",
    "tracking",
    "sdk"
  ],
  "author": "Pug",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "jsdom": "^29.0.1",
    "serve": "^14.2.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  }
}
