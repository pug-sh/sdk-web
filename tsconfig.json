{
  "compilerOptions": {
    "declaration": true,
    "forceConsistentCasingInFileNames": true,
    "module": "es2020",
    "moduleResolution": "bundler",
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "strict": true,
    "target": "es2020"
  },
  "include": ["src/**/*"],
  // *.test-d.ts holds type-level tests: checked by tsconfig.typecheck.json, never emitted to dist.
  "exclude": ["src/**/*.test.ts", "src/**/*.test-d.ts"]
}
